{
  "name": "begifted",
  "main": "expo-router/entry",
  "version": "1.0.1",
  "scripts": {
    "start": "EXPO_OFFLINE=0 expo start",
    "update": "eas update --branch production",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "EXPO_OFFLINE=0 expo start --android",
    "ios": "EXPO_OFFLINE=0 expo start --ios",
    "web": "EXPO_OFFLINE=0 expo start --web",
    "lint": "expo lint",
    "format": "npx prettier --write \"**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "npx prettier --check \"**/*.{ts,tsx,js,jsx,json}\"",
    "export": "expo export --platform web",
    "build": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "test": "TZ=UTC jest",
    "prepare": "husky"
  },
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/app",
      "<rootDir>/components",
      "<rootDir>/hooks",
      "<rootDir>/lib",
      "<rootDir>/utils"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/azeret-mono": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/poltawski-nowy": "^0.4.2",
    "@expo-google-fonts/roboto-flex": "^0.4.1",
    "@expo/config-plugins": "~57.0.0",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/elements": "^2.9.30",
    "@react-navigation/native": "^7.3.8",
    "@sentry/react-native": "^8.17.2",
    "@supabase/supabase-js": "^2.110.1",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "expo": "^57.0.0",
    "expo-blur": "~57.0.0",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-contacts": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.65.0",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-paper": "^5.12.5",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.4",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~57.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "plugins": [
    "prettier"
  ],
  "lint-staged": {
    "{app,components}/**/*.{ts,tsx}": "eslint --fix",
    "*.{ts,tsx,js,jsx,json}": "prettier --write"
  },
  "private": true
}
