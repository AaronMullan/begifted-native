#!/bin/bash
# Headless entry point for the Sentry pipelines, invoked by launchd
# (com.begifted.sentry-autofix) on weekday mornings. Prepares dedicated bot
# clones so the runs can never touch the human working checkouts, then runs
# claude -p against the begifted-native clone: /sentry-autofix (error → PR),
# /sentry-feedback-to-jira headless (feedback → ticket), and /slack-to-jira
# sweep #bugs (Slack bug report → ticket).
set -euo pipefail

MAIN_CHECKOUT="$HOME/development/begifted-native"
AUTOFIX_ROOT="$HOME/development/autofix"
LOG_DIR="$HOME/Library/Logs/begifted-autofix"
LOCK_DIR="$LOG_DIR/.lock"
CLAUDE_BIN="$HOME/.local/bin/claude"
AUTOFIX_TIMEOUT_SECS=3600
FEEDBACK_TIMEOUT_SECS=1200
SWEEP_TIMEOUT_SECS=1200
NOTIFY_TIMEOUT_SECS=300
REPOS=(begifted-native be-gifted)

mkdir -p "$LOG_DIR" "$AUTOFIX_ROOT"
LOG="$LOG_DIR/$(date +%Y-%m-%d).log"
exec >>"$LOG" 2>&1
echo "=== autofix run $(date '+%Y-%m-%d %H:%M:%S') ==="

notify() {
  /usr/bin/osascript -e "display notification \"$1\" with title \"Sentry autofix\"" || true
}

# mkdir is atomic: a second run while one is in flight skips instead of
# stacking git resets and claude sessions on the same clones.
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  echo "another run holds the lock at $LOCK_DIR — skipping"
  exit 0
fi
trap 'rmdir "$LOCK_DIR"' EXIT

fail() {
  echo "FAILED: $1"
  notify "failed — see $(basename "$LOG")"
  exit 1
}

for repo in "${REPOS[@]}"; do
  clone="$AUTOFIX_ROOT/$repo"
  if [ ! -d "$clone/.git" ]; then
    echo "cloning $repo"
    git clone "git@github.com:AaronMullan/$repo.git" "$clone" || fail "clone $repo"
  fi
  git -C "$clone" fetch origin || fail "fetch $repo"
  git -C "$clone" checkout main -q || fail "checkout main $repo"
  git -C "$clone" reset --hard origin/main -q || fail "reset $repo"
  git -C "$clone" clean -fd -q || fail "clean $repo"

  # npm ci only when the lockfile changed — installs dominate run time otherwise.
  lockhash=$(shasum "$clone/package-lock.json" | cut -d' ' -f1)
  hashfile="$clone/.autofix-lockhash"
  if [ ! -f "$hashfile" ] || [ "$(cat "$hashfile")" != "$lockhash" ]; then
    echo "npm ci in $repo (lockfile changed)"
    (cd "$clone" && npm ci --no-audit --no-fund) || fail "npm ci $repo"
    echo "$lockhash" >"$hashfile"
  fi
done

# The Sentry token lives only in the human checkout's untracked .env.local.
cp "$MAIN_CHECKOUT/.env.local" "$AUTOFIX_ROOT/begifted-native/.env.local" || fail "copy .env.local"

# macOS has no `timeout`; watchdog-kill a run if it wedges past its budget.
run_claude() {
  local prompt="$1" budget="$2" label="${3:-$1}" status=0
  echo "--- $label ($(date '+%H:%M:%S')) ---"
  "$CLAUDE_BIN" -p "$prompt" --dangerously-skip-permissions &
  local claude_pid=$!
  (
    sleep "$budget"
    echo "TIMEOUT after ${budget}s — killing claude ($prompt)"
    kill "$claude_pid" 2>/dev/null
  ) &
  local watchdog_pid=$!
  wait "$claude_pid" || status=$?
  # Reap the watchdog so bash doesn't print an async "Terminated" job notice
  # into the log.
  { kill "$watchdog_pid" && wait "$watchdog_pid"; } 2>/dev/null || true
  return "$status"
}

cd "$AUTOFIX_ROOT/begifted-native"

# The passes are independent — a wedged pass must not starve the others —
# so run all of them unconditionally and report failures together.
AUTOFIX_STATUS=0
run_claude "/sentry-autofix" "$AUTOFIX_TIMEOUT_SECS" || AUTOFIX_STATUS=$?
FEEDBACK_STATUS=0
run_claude "/sentry-feedback-to-jira headless" "$FEEDBACK_TIMEOUT_SECS" || FEEDBACK_STATUS=$?
SWEEP_STATUS=0
run_claude "/slack-to-jira sweep #bugs" "$SWEEP_TIMEOUT_SECS" || SWEEP_STATUS=$?

find "$LOG_DIR" -name '*.log' -mtime +30 -delete || true

FAILURES=""
if [ "$AUTOFIX_STATUS" -ne 0 ]; then
  FAILURES="autofix exited $AUTOFIX_STATUS"
fi
if [ "$FEEDBACK_STATUS" -ne 0 ]; then
  FAILURES="${FAILURES:+$FAILURES; }feedback exited $FEEDBACK_STATUS"
fi
if [ "$SWEEP_STATUS" -ne 0 ]; then
  FAILURES="${FAILURES:+$FAILURES; }slack sweep exited $SWEEP_STATUS"
fi
# DM Aaron the run summary. This is the one place a real slack_send_message
# (not a draft) is authorized: it's a self-notification to the authenticated
# user, nothing a teammate sees. Runs on failure too, so a broken pass still
# surfaces in Slack; the DM itself failing must not fail the run.
OUTCOME="${FAILURES:-all passes completed}"
NOTIFY_PROMPT="Read today's overnight triage log at $LOG. Then send a Slack DM to myself — the authenticated Slack user — summarizing the run: one short line per pass (sentry-autofix, sentry-feedback-to-jira, #bugs sweep) saying what was filed/opened/archived or that it was quiet, and lead with any failures. Overall outcome: $OUTCOME. Use slack_send_message to my own DM channel; a real send (not a draft) is explicitly authorized for this self-notification. Do not message anyone else or post in any channel."
run_claude "$NOTIFY_PROMPT" "$NOTIFY_TIMEOUT_SECS" "slack DM notification" || echo "slack notify failed (non-fatal)"

if [ -n "$FAILURES" ]; then
  fail "$FAILURES"
fi

notify "autofix + feedback + slack sweep complete — details in $(basename "$LOG")"
echo "=== run complete $(date '+%H:%M:%S') ==="
