{
  "expo": {
    "name": "begifted",
    "slug": "begifted",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "begifted",
    "userInterfaceStyle": "automatic",
    "ios": {
      "buildNumber": "17",
      "bundleIdentifier": "com.begifted.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "This app would like to access your contacts to help you import gift recipients.",
        "NSPhotoLibraryUsageDescription": "BeGifted needs access to your photos so you can attach a screenshot to a bug report.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.begifted.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["READ_CONTACTS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#7da4b0",
          "android": {
            "image": "./assets/images/splash-blank.png"
          }
        }
      ],
      "expo-font",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "BeGifted needs access to your photos so you can attach a screenshot to a bug report."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "begifted"
        }
      ],
      "@sentry/react-native",
      "expo-image",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "16c0ca90-545c-4ff3-be91-227aae28dbe5"
      }
    },
    "owner": "aaronmullan",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/16c0ca90-545c-4ff3-be91-227aae28dbe5"
    }
  }
}
